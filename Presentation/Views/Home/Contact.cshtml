@{
  ViewData["Title"] = "Liên hệ";
  Layout = "~/Views/Shared/_LayoutClient.cshtml";
}

<style>
  .contact-section {
    padding: 80px 0;
    background: white;
  }

  /* Contact Info Cards */
  .contact-info-cards {
    margin-bottom: 80px;
  }

  .contact-info-card {
    background: white;
    padding: 40px 30px;
    border-radius: 8px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    height: 100%;
  }

  .contact-info-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(212, 165, 116, 0.15);
  }

  .contact-icon {
    font-size: 42px;
    color: var(--primary-color);
    margin-bottom: 20px;
  }

  .contact-info-card h5 {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 15px;
  }

  .contact-info-card p {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  .contact-info-card a {
    color: var(--primary-color);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .contact-info-card a:hover {
    color: var(--primary-dark);
    text-decoration: underline;
  }

  /* Contact Form Section */
  .contact-form-section {
    background: linear-gradient(135deg, var(--light-bg) 0%, var(--light-bg-2) 100%);
    padding: 60px 0;
    margin: 60px 0;
  }

  .contact-form-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 40px;
  }

  .contact-form-container {
    background: white;
    padding: 40px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .contact-form {
    max-width: 600px;
    margin: 0 auto;
  }

  .form-group {
    margin-bottom: 25px;
  }

  .contact-form label {
    display: block;
    margin-bottom: 10px;
    font-weight: 600;
    color: var(--dark-color);
    font-size: 14px;
  }

  .contact-form .form-control {
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: 12px 16px;
    font-size: 14px;
    font-family: 'Poppins', sans-serif;
    transition: all 0.3s ease;
  }

  .contact-form .form-control:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(212, 165, 116, 0.1);
    outline: none;
  }

  .contact-form textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-form button {
    width: 100%;
    padding: 14px;
    font-size: 15px;
    font-weight: 600;
    background: var(--primary-color);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .contact-form button:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(212, 165, 116, 0.3);
  }

  /* Contact Map */
  .contact-map-section {
    margin: 60px 0;
  }

  .contact-map-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 30px;
  }

  .contact-map {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    height: 400px;
  }

  .contact-map iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  /* FAQ Section */
  .faq-section {
    padding: 60px 0;
    background: linear-gradient(135deg, var(--light-bg) 0%, var(--light-bg-2) 100%);
    margin: 60px 0;
  }

  .faq-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--dark-color);
    text-align: center;
    margin-bottom: 50px;
  }

  .faq-accordion {
    max-width: 700px;
    margin: 0 auto;
  }

  .accordion-item {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    margin-bottom: 15px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .accordion-item:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .accordion-header {
    padding: 0;
  }

  .accordion-button {
    background: white;
    border: none;
    color: var(--dark-color);
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    padding: 20px;
    text-align: left;
    transition: all 0.3s ease;
  }

  .accordion-button:not(.collapsed) {
    background: var(--light-bg);
    color: var(--primary-color);
    box-shadow: none;
  }

  .accordion-button::after {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23d4a574' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M5 8l6 6 6-6'/%3e%3c/svg%3e");
  }

  .accordion-button:focus {
    box-shadow: none;
    border-color: var(--primary-color);
  }

  .accordion-body {
    padding: 20px;
    background: white;
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.8;
    border-top: 1px solid #e0e0e0;
  }

  /* Newsletter Section */
  .newsletter-section {
    padding: 60px 0;
    background: white;
  }

  .newsletter-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--dark-color);
  }

  .newsletter-form {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    max-width: 500px;
    margin: 0 auto;
  }

  .newsletter-form input {
    flex: 1;
    min-width: 250px;
    padding: 12px 20px;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-size: 14px;
  }

  .newsletter-form button {
    padding: 12px 30px;
    white-space: nowrap;
  }

  @@media (max-width: 768px) {
    .contact-section {
      padding: 60px 0;
    }

    .contact-form-container {
      padding: 25px;
    }

    .contact-form-title,
    .contact-map-title,
    .faq-title {
      font-size: 24px;
    }

    .contact-map {
      height: 300px;
    }

    .contact-info-card {
      padding: 30px 20px;
    }

    .accordion-button {
      padding: 15px;
      font-size: 14px;
    }

    .accordion-body {
      padding: 15px;
    }

    .newsletter-form {
      flex-direction: column;
    }

    .newsletter-form input {
      min-width: 100%;
    }
  }
</style>

<!-- Contact Section -->
<section class="contact-section">
  <div class="container">
    <h1 class="section-title text-center mb-5">Liên hệ với chúng tôi</h1>

    <!-- Contact Info Cards -->
    <div class="contact-info-cards">
      <div class="row">
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="contact-info-card">
            <div class="contact-icon">
              <i class="fas fa-map-marker-alt"></i>
            </div>
            <h5>Địa chỉ</h5>
            <p>
              123 Đường ABC<br />
              Quận 1, TP.HCM<br />
              Việt Nam
            </p>
          </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="contact-info-card">
            <div class="contact-icon">
              <i class="fas fa-phone"></i>
            </div>
            <h5>Liên hệ</h5>
            <p>
              <a href="tel:0912345678">0912 345 678</a><br />
              <a href="mailto:info@birthdaycakeshop.com">info@birthdaycakeshop.com</a>
            </p>
          </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="contact-info-card">
            <div class="contact-icon">
              <i class="fas fa-clock"></i>
            </div>
            <h5>Giờ làm việc</h5>
            <p>
              Thứ 2 - Thứ 7: 8:00 - 22:00<br />
              Chủ nhật: 9:00 - 21:00<br />
              Đóng cửa vào ngày lễ
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact Form Section -->
<section class="contact-form-section">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 mx-auto">
        <h2 class="contact-form-title text-center">Gửi tin nhắn cho chúng tôi</h2>
        <div class="contact-form-container">
          <form class="contact-form">
            <div class="form-group">
              <label for="name">Họ và tên *</label>
              <input type="text" class="form-control" id="name" name="name" required />
            </div>

            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" class="form-control" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="phone">Số điện thoại *</label>
              <input type="tel" class="form-control" id="phone" name="phone" required />
            </div>

            <div class="form-group">
              <label for="subject">Chủ đề *</label>
              <select class="form-control" id="subject" name="subject" required>
                <option value="">-- Chọn chủ đề --</option>
                <option value="order">Câu hỏi về đơn hàng</option>
                <option value="product">Tư vấn sản phẩm</option>
                <option value="complaint">Khiếu nại / Gợi ý</option>
                <option value="partnership">Hợp tác kinh doanh</option>
                <option value="other">Khác</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Nội dung *</label>
              <textarea class="form-control" id="message" name="message" required></textarea>
            </div>

            <button type="submit" class="btn-submit">Gửi tin nhắn</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact Map Section -->
<section class="contact-map-section">
  <div class="container">
    <h2 class="contact-map-title text-center">Vị trí cửa hàng</h2>
    <div class="contact-map">
      <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.5268374355596!2d106.6996161!3d10.7629557!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f36b0b0b0b1%3A0x1f6b5f5f5f5f5f5f!2sDistrict%201%2C%20Ho%20Chi%20Minh%20City!5e0!3m2!1sen!2s!4v1234567890"
      allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section class="faq-section">
  <div class="container">
    <h2 class="faq-title">Câu hỏi thường gặp</h2>
    <div class="faq-accordion">
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
            Tôi có thể đặt bánh trước bao lâu?
          </button>
        </h2>
        <div id="faq1" class="accordion-collapse collapse" data-bs-parent=".faq-accordion">
          <div class="accordion-body">
            Chúng tôi khuyến cáo đặt bánh ít nhất 2-3 ngày trước ngày nhận. Tuy nhiên, đối với các đơn hàng gấp,
            chúng tôi có thể chế biến trong 4-6 giờ nếu đơn hàng đặt trước 10:00 sáng. Hãy liên hệ với chúng tôi
            để xác nhận khả năng sẵn lòng.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
            Birthday Cake Shop có giao hàng không?
          </button>
        </h2>
        <div id="faq2" class="accordion-collapse collapse" data-bs-parent=".faq-accordion">
          <div class="accordion-body">
            Có, chúng tôi cung cấp dịch vụ giao hàng miễn phí cho các đơn hàng từ 500.000 VNĐ trở lên trong vùng
            Thành phố. Đối với các đơn hàng dưới mức này hoặc ở các vùng khác, sẽ có phí giao hàng. Liên hệ với
            chúng tôi để biết chi tiết.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
            Bánh có chứa allergen không?
          </button>
        </h2>
        <div id="faq3" class="accordion-collapse collapse" data-bs-parent=".faq-accordion">
          <div class="accordion-body">
            Bánh của chúng tôi chủ yếu chứa đạm (trứng, sữa, hạt cây). Nếu bạn hoặc khách mời của bạn có dị ứng,
            vui lòng thông báo trước khi đặt hàng hoặc liên hệ với chúng tôi để chúng tôi có thể tìm ra giải pháp
            phù hợp.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
            Chính sách hoàn trả / Hủy đơn hàng là gì?
          </button>
        </h2>
        <div id="faq4" class="accordion-collapse collapse" data-bs-parent=".faq-accordion">
          <div class="accordion-body">
            Chúng tôi không chấp nhận hoàn trả bánh vì lý do vệ sinh. Tuy nhiên, nếu bánh có lỗi do lỗi của chúng
            tôi, chúng tôi sẽ làm lại hoặc hoàn tiền. Hủy đơn hàng phải được thông báo ít nhất 2 ngày trước ngày
            giao hàng để hoàn tiền 100%.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Newsletter Section -->
<section class="newsletter-section">
  <div class="container text-center">
    <h2 class="mb-4">Nhận tặng 10% cho đơn hàng đầu tiên</h2>
    <form class="newsletter-form">
      <input type="email" placeholder="Nhập email của bạn" required />
      <button type="submit" class="btn btn-primary">Đăng ký</button>
    </form>
  </div>
</section>