   @{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_LayoutClient.cshtml";
}
    <!-- Contact Section -->
    <section class="contact-section py-5">
      <div class="container">
        <h1 class="section-title text-center mb-5">Liên hệ với chúng tôi</h1>

        <div class="row mb-5">
          <!-- Contact Info -->
          <div class="col-lg-4 mb-4">
            <div class="contact-info-card">
              <div class="contact-icon">
                <i class="fas fa-map-marker-alt"></i>
              </div>
              <h5>Địa chỉ</h5>
              <p>123 Đường Lê Duân, Quận Hoàn Kiếm, Hà Nội, Việt Nam</p>
              <a href="#">Xem bản đồ</a>
            </div>
          </div>

          <div class="col-lg-4 mb-4">
            <div class="contact-info-card">
              <div class="contact-icon">
                <i class="fas fa-phone-alt"></i>
              </div>
              <h5>Liên hệ</h5>
              <p><strong>Điện thoại:</strong> 0123 456 789</p>
              <p><strong>Zalo/WhatsApp:</strong> 0987 654 321</p>
              <p><strong>Email:</strong> hello@sweetcake.vn</p>
            </div>
          </div>

          <div class="col-lg-4 mb-4">
            <div class="contact-info-card">
              <div class="contact-icon">
                <i class="fas fa-clock"></i>
              </div>
              <h5>Giờ làm việc</h5>
              <p><strong>Thứ 2 - Thứ 6:</strong> 8:00 - 22:00</p>
              <p><strong>Thứ 7 - Chủ nhật:</strong> 9:00 - 23:00</p>
              <p>Tết Nguyên Đán: 10:00 - 20:00</p>
            </div>
          </div>
        </div>

        <!-- Contact Form & Map -->
        <div class="row">
          <div class="col-lg-7">
            <h3 class="mb-4">Gửi tin nhắn cho chúng tôi</h3>
            <form class="contact-form">
              <div class="form-group">
                <label>Họ và tên *</label>
                <input
                  type="text"
                  class="form-control"
                  placeholder="Nhập họ và tên"
                  required
                />
              </div>

              <div class="form-row">
                <div class="form-group col-md-6">
                  <label>Email *</label>
                  <input
                    type="email"
                    class="form-control"
                    placeholder="Nhập email"
                    required
                  />
                </div>
                <div class="form-group col-md-6">
                  <label>Số điện thoại *</label>
                  <input
                    type="tel"
                    class="form-control"
                    placeholder="Nhập số điện thoại"
                    required
                  />
                </div>
              </div>

              <div class="form-group">
                <label>Chủ đề *</label>
                <select class="form-control" required>
                  <option value="">-- Chọn chủ đề --</option>
                  <option value="inquiry">Đặt hàng/ Tư vấn</option>
                  <option value="feedback">Góp ý</option>
                  <option value="complaint">Khiếu nại</option>
                  <option value="partnership">Hợp tác kinh doanh</option>
                  <option value="other">Khác</option>
                </select>
              </div>

              <div class="form-group">
                <label>Nội dung tin nhắn *</label>
                <textarea
                  class="form-control"
                  rows="6"
                  placeholder="Nhập nội dung tin nhắn"
                  required
                ></textarea>
              </div>

              <div class="form-check mb-4">
                <input
                  class="form-check-input"
                  type="checkbox"
                  id="agree"
                  checked
                />
                <label class="form-check-label" for="agree">
                  Tôi đồng ý với <a href="#">Chính sách bảo mật</a>
                </label>
              </div>

              <button type="submit" class="btn btn-primary btn-lg">
                Gửi tin nhắn
              </button>
            </form>
          </div>

          <div class="col-lg-5">
            <!-- Map -->
            <div class="contact-map mb-4">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3724.5687263913745!2d105.85316137618384!3d21.00661488765633!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ab9bd9861ca1%3A0xbb20ee49c6430d59!2sHoan%20Kiem%20Lake!5e0!3m2!1sen!2s!4v1234567890"
                width="100%"
                height="400"
                style="border: 0"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>

            <!-- FAQ -->
            <h5 class="mb-4">Câu hỏi thường gặp</h5>
            <div class="accordion" id="faqAccordion">
              <div class="card mb-2">
                <div class="card-header" id="heading1">
                  <h6 class="mb-0">
                    <button
                      class="btn btn-link"
                      type="button"
                      data-toggle="collapse"
                      data-target="#collapse1"
                    >
                      Thời gian giao hàng bao lâu?
                    </button>
                  </h6>
                </div>
                <div
                  id="collapse1"
                  class="collapse"
                  data-parent="#faqAccordion"
                >
                  <div class="card-body">
                    Chúng tôi cung cấp 2 phương thức giao hàng:
                    <ul>
                      <li>Express: 2-3 giờ</li>
                      <li>Tiêu chuẩn: 6-8 giờ</li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="card mb-2">
                <div class="card-header" id="heading2">
                  <h6 class="mb-0">
                    <button
                      class="btn btn-link"
                      type="button"
                      data-toggle="collapse"
                      data-target="#collapse2"
                    >
                      Có thể đặt bánh trước không?
                    </button>
                  </h6>
                </div>
                <div
                  id="collapse2"
                  class="collapse"
                  data-parent="#faqAccordion"
                >
                  <div class="card-body">
                    Có, bạn có thể đặt bánh từ 1-7 ngày trước. Chúng tôi sẽ làm
                    bánh tươi cho bạn!
                  </div>
                </div>
              </div>

              <div class="card mb-2">
                <div class="card-header" id="heading3">
                  <h6 class="mb-0">
                    <button
                      class="btn btn-link"
                      type="button"
                      data-toggle="collapse"
                      data-target="#collapse3"
                    >
                      Có đổi trả được không?
                    </button>
                  </h6>
                </div>
                <div
                  id="collapse3"
                  class="collapse"
                  data-parent="#faqAccordion"
                >
                  <div class="card-body">
                    Có, chúng tôi chấp nhận đổi trả bánh trong 7 ngày nếu bánh
                    không đạt chất lượng.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter Section -->
    <section class="newsletter-section py-5">
      <div class="container text-center">
        <h2 class="mb-3">Nhận tặng 10% cho đơn hàng đầu tiên</h2>
        <form class="newsletter-form">
          <input type="email" placeholder="Nhập email của bạn" required />
          <button type="submit" class="btn btn-primary">Đăng ký</button>
        </form>
      </div>
    </section>