@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_LayoutClient.cshtml";
}

    <!-- About Section -->
    <section class="about-section py-5">
      <div class="container">
        <h1 class="section-title text-center mb-5">Về Sweet Cake Paradise</h1>

        <!-- Story -->
        <div class="row align-items-center mb-5">
          <div class="col-lg-6">
            <img
              src="https://via.placeholder.com/500x400?text=Our+Story"
              alt="Our Story"
              class="img-fluid rounded"
            />
          </div>
          <div class="col-lg-6 pl-5">
            <h3 class="mb-3">Câu chuyện của chúng tôi</h3>
            <p>
              Sweet Cake Paradise được thành lập vào năm 2019 bởi một nhóm những
              người đam mê làm bánh. Với mục đích mang đến những chiếc bánh tươi
              mới, chất lượng cao nhất cho mỗi gia đình Việt Nam.
            </p>
            <p>
              Từ những ngày đầu tiên chỉ với một bếp nhỏ trong ngôi nhà, chúng
              tôi đã phục vụ hàng trăm khách hàng thân thiết. Nhờ vào sự ủng hộ
              và yêu thương từ các khách hàng, Sweet Cake Paradise đã phát triển
              thành một thương hiệu bánh được yêu thích trên toàn quốc.
            </p>
            <p>
              Hôm nay, chúng tôi tự hào phục vụ hàng nghìn khách hàng mỗi tháng
              với các sản phẩm chất lượng cao và dịch vụ xuất sắc.
            </p>
          </div>
        </div>

        <!-- Values -->
        <div class="row mt-5">
          <div class="col-12 mb-5">
            <h3 class="text-center mb-4">Giá trị của chúng tôi</h3>
          </div>
          <div class="col-md-4 mb-4">
            <div class="value-card">
              <div class="value-icon">
                <i class="fas fa-heart"></i>
              </div>
              <h5>Chất lượng</h5>
              <p>
                Chúng tôi cam kết sử dụng những nguyên liệu tốt nhất, được lựa
                chọn cẩn thận để đảm bảo chất lượng sản phẩm tuyệt vời.
              </p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="value-card">
              <div class="value-icon">
                <i class="fas fa-handshake"></i>
              </div>
              <h5>Sự tín cậy</h5>
              <p>
                Với hơn 5 năm hoạt động, chúng tôi đã xây dựng được lòng tin từ
                hàng triệu khách hàng trên khắp đất nước.
              </p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="value-card">
              <div class="value-icon">
                <i class="fas fa-lightbulb"></i>
              </div>
              <h5>Sáng tạo</h5>
              <p>
                Chúng tôi liên tục sáng tạo và phát triển những hương vị bánh
                mới để thỏa mãn nhu cầu đa dạng của khách hàng.
              </p>
            </div>
          </div>
        </div>

        <!-- Team -->
        <div class="row mt-5">
          <div class="col-12 mb-5">
            <h3 class="text-center mb-4">Đội ngũ chúng tôi</h3>
          </div>
          <div class="col-md-3 mb-4">
            <div class="team-card">
              <img
                src="https://via.placeholder.com/300x300?text=Team+1"
                alt="Team Member"
                class="img-fluid rounded-top"
              />
              <div class="team-info">
                <h6>Nguyễn Thị Hương</h6>
                <small>CEO & Founder</small>
                <p>
                  Tốt nghiệp chuyên ngành Quản lý kinh doanh tại ĐH Kinh tế Quốc
                  dân. Có 10 năm kinh nghiệm trong lĩnh vực bánh.
                </p>
              </div>
            </div>
          </div>
          <div class="col-md-3 mb-4">
            <div class="team-card">
              <img
                src="https://via.placeholder.com/300x300?text=Team+2"
                alt="Team Member"
                class="img-fluid rounded-top"
              />
              <div class="team-info">
                <h6>Tạ Văn Minh</h6>
                <small>Head Chef</small>
                <p>
                  Học bánh tại Pháp, có 8 năm kinh nghiệm. Đã tạo ra nhiều công
                  thức bánh độc quyền cho Sweet Cake.
                </p>
              </div>
            </div>
          </div>
          <div class="col-md-3 mb-4">
            <div class="team-card">
              <img
                src="https://via.placeholder.com/300x300?text=Team+3"
                alt="Team Member"
                class="img-fluid rounded-top"
              />
              <div class="team-info">
                <h6>Phạm Hồng Phương</h6>
                <small>Design Manager</small>
                <p>
                  Chuyên gia trong thiết kế bánh, luôn mang đến những ý tưởng
                  sáng tạo cho mỗi sản phẩm.
                </p>
              </div>
            </div>
          </div>
          <div class="col-md-3 mb-4">
            <div class="team-card">
              <img
                src="https://via.placeholder.com/300x300?text=Team+4"
                alt="Team Member"
                class="img-fluid rounded-top"
              />
              <div class="team-info">
                <h6>Lê Thu Hà</h6>
                <small>Customer Service Manager</small>
                <p>
                  Đảm bảo mỗi khách hàng nhận được dịch vụ tốt nhất. Luôn sẵn
                  sàng lắng nghe ý kiến từ khách hàng.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Achievements -->
        <div class="row mt-5">
          <div class="col-12 mb-5">
            <h3 class="text-center mb-4">Thành tích đạt được</h3>
          </div>
          <div class="col-md-3 mb-4 text-center">
            <div class="achievement">
              <h3 class="achievement-number">5+</h3>
              <p>Năm hoạt động</p>
            </div>
          </div>
          <div class="col-md-3 mb-4 text-center">
            <div class="achievement">
              <h3 class="achievement-number">50K+</h3>
              <p>Khách hàng lâu năm</p>
            </div>
          </div>
          <div class="col-md-3 mb-4 text-center">
            <div class="achievement">
              <h3 class="achievement-number">100+</h3>
              <p>Loại bánh khác nhau</p>
            </div>
          </div>
          <div class="col-md-3 mb-4 text-center">
            <div class="achievement">
              <h3 class="achievement-number">4.9/5</h3>
              <p>Đánh giá trung bình</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section py-5 text-center">
      <div class="container">
        <h2 class="mb-4">Bạn sẵn sàng cho một trải nghiệm bánh tuyệt vời?</h2>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-primary btn-lg">Khám phá cửa hàng</a>
      </div>
    </section>

    <!-- Newsletter Section -->
    <section class="newsletter-section py-5">
      <div class="container text-center">
        <h2 class="mb-3">Nhận tặng 10% cho đơn hàng đầu tiên</h2>
        <form class="newsletter-form">
          <input type="email" placeholder="Nhập email của bạn" required />
          <button type="submit" class="btn btn-primary">Đăng ký</button>
        </form>
      </div>
    </section>
