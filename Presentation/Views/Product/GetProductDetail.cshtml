@using Presentation.ViewModels
@{
  ViewData["Title"] = @Model.Name + " - Chi tiết sản phẩm";
  Layout = "~/Views/Shared/_LayoutClient.cshtml";
}
@model ProductDetailView

<style>
  .product-detail-section {
    padding: 60px 0;
    min-height: calc(100vh - 400px);
  }

  .product-images {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .main-image {
    background: linear-gradient(135deg, #f5f1ed 0%, #f9f6f2 100%);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30px;
    height: 400px;
  }

  .main-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    max-width: 350px;
    max-height: 350px;
  }

  .thumbnail-images {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  .thumbnail-images img {
    width: 100%;
    border-radius: 6px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.3s ease;
    object-fit: cover;
    height: 80px;
  }

  .thumbnail-images img:hover {
    border-color: #d4a574;
    transform: scale(1.05);
  }

  .product-details {
    padding: 20px 0;
  }

  .product-title {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 15px;
    line-height: 1.3;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid #e0e0e0;
  }

  .product-rating .stars {
    color: #ffc107;
    font-size: 16px;
    display: flex;
    gap: 3px;
  }

  .rating-text {
    color: #666;
    font-size: 14px;
  }

  .review-link {
    color: #d4a574;
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s;
  }

  .review-link:hover {
    color: #c29456;
  }

  .product-price {
    margin-bottom: 20px;
  }

  .price-current {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: #d4a574;
  }

  .product-description {
    color: #666;
    line-height: 1.8;
    margin-bottom: 30px;
  }

  .product-options {
    background: #f5f1ed;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 25px;
  }

  .option-label {
    font-weight: 600;
    color: #1a1a1a;
    display: block;
    margin-bottom: 8px;
  }

  .product-buttons {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
  }

  .quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    overflow: hidden;
  }

  .qty-btn {
    background: #f5f1ed;
    border: none;
    width: 40px;
    height: 40px;
    cursor: pointer;
    font-weight: 600;
    color: #d4a574;
    transition: all 0.3s;
  }

  .qty-btn:hover {
    background: #d4a574;
    color: white;
  }

  .quantity-selector input {
    border: none;
    width: 60px;
    text-align: center;
    padding: 0;
    font-weight: 600;
  }

  .quantity-selector input:focus {
    outline: none;
    background: #f9f6f2;
  }

  .btn-primary {
    flex-grow: 1;
    padding-top: 12px;
    padding-bottom: 12px;
    font-weight: 600;
  }

  .btn-outline-danger {
    border: 2px solid #e74c3c;
    color: #e74c3c;
    background: transparent;
    padding: 10px 20px;
    border-radius: 6px;
    width: 100%;
    cursor: pointer;
    transition: all 0.3s;
    font-weight: 600;
  }

  .btn-outline-danger:hover {
    background: #e74c3c;
    color: white;
  }

  .product-meta {
    padding-top: 25px;
    border-top: 1px solid #e0e0e0;
  }

  .meta-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
    padding: 10px 0;
  }

  .meta-label {
    font-weight: 600;
    color: #1a1a1a;
  }

  .meta-value {
    color: #666;
  }

  .social-share {
    display: flex;
    gap: 10px;
  }

  .social-share a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: #f5f1ed;
    color: #d4a574;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.3s;
  }

  .social-share a:hover {
    background: #d4a574;
    color: white;
  }

  @@media (max-width: 768px) {
    .product-title {
      font-size: 24px;
    }

    .main-image {
      height: 300px;
    }

    .product-buttons {
      flex-direction: column;
    }

    .quantity-selector {
      width: 100%;
    }

    .thumbnail-images {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<!-- Product Detail Section -->
<section class="product-detail-section">
  <div class="container">
    <div class="row">
      <!-- Product Images -->
      <div class="col-lg-5 mb-5">
        <div class="product-images">
          <div class="main-image">
            <img src="@Url.Content("~/Client/img/product/" + @Model.Thumbnail)" id="mainImage" alt="@Model.Name" />
          </div>
          @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
          {
            <div class="thumbnail-images">
              <img src="@Url.Content("~/Client/img/product/" + @Model.Thumbnail)" alt="Ảnh chính"
                   onclick="changeImage(this)" style="border-color: #d4a574;" />
              @foreach (var item in Model.ImageUrls)
              {
                <img src="@Url.Content("~/Client/img/product/details/" + @item)" alt="Chi tiết"
                     onclick="changeImage(this)" />
              }
            </div>
          }
        </div>
      </div>

      <!-- Product Information -->
      <div class="col-lg-7">
        <div class="product-details">
          <h1 class="product-title">@Model.Name</h1>

          <div class="product-rating">
            <div class="stars">
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star-half-alt"></i>
            </div>
            <span class="rating-text">(28 đánh giá)</span>
            <a href="#reviews" class="review-link">Xem đánh giá</a>
          </div>

          <div class="product-price">
            <span class="price-current">@Model.Price VNĐ</span>
          </div>

          <div class="product-description">
            @Model.Description
          </div>

          <!-- Product Options -->
          <div class="product-options">
            <label class="option-label">🎂 Kích thước bánh: @Model.CakeSize</label>
            <label class="option-label">🍰 Hương vị: @Model.Flavor</label>
          </div>

          <!-- Quantity and Buttons -->
          <form asp-controller="Cart" asp-action="AddCartItem" method="post">
            <input type="hidden" name="ProductDetailId" value="@Model.Id" />
            <input type="hidden" name="ProductId" value="@Model.ProductId" />

            <div class="product-buttons">
              <div class="quantity-selector">
                <button type="button" class="qty-btn" onclick="decreaseQty()">−</button>
                <input type="number" id="quantity" name="quantity" value="1" min="1" />
                <button type="button" class="qty-btn" onclick="increaseQty()">+</button>
              </div>
              <button type="submit" class="btn btn-primary btn-lg">
                <i class="fas fa-shopping-cart"></i> Thêm vào giỏ
              </button>
            </div>
          </form>

          <button class="btn-outline-danger" type="button">
            <i class="fas fa-heart"></i> Thêm vào yêu thích
          </button>

          <!-- Product Meta -->
          <div class="product-meta">
            <div class="meta-item">
              <span class="meta-label">📁 Danh mục:</span>
              <span class="meta-value">@Model.CategoryName</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">✓ Tình trạng:</span>
              <span class="meta-value" style="color: #27ae60; font-weight: 600;">Còn hàng</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">📱 Chia sẻ:</span>
              <div class="social-share">
                <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
                <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                <a href="#" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

@section Scripts {
  <script>
    function increaseQty() {
      let qty = document.getElementById("quantity");
      qty.value = parseInt(qty.value) + 1;
    }

    function decreaseQty() {
      let qty = document.getElementById("quantity");
      if (qty.value > 1) {
        qty.value = parseInt(qty.value) - 1;
      }
    }

    function changeImage(element) {
      let mainImage = document.getElementById("mainImage");
      mainImage.src = element.src;

      // Update active thumbnail
      document.querySelectorAll(".thumbnail-images img").forEach(img => {
        img.style.borderColor = "transparent";
      });
      element.style.borderColor = "#d4a574";
    }
  </script>
}
</script>
}