@using Presentation.ViewModels
 @{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_LayoutClient.cshtml";
}
@model ProductDetailView
    <section class="product-details-section py-5">
      <div class="container">
        <div class="row">
          <!-- Product Images -->
          <div class="col-lg-6 mb-5">
            <div class="product-images">
              <div class="main-image mb-3">
                <img
                  src="@Url.Content("~/Client/img/product/" + @Model.Thumbnail)"
                  id="mainImage"
                  alt="@Model.Name"
                />
              </div>
              <div class="thumbnail-images">
                @foreach(var item in Model.ImageUrls)
                {
                  <img
                    src="@Url.Content("~/Client/img/product/details/" + @item)"
                    alt="View 4"
                    class="thumbnail"
                    onclick="changeImage(this)"
                  />
                }
              </div>
            </div>
          </div>

          <!-- Product Information -->
          <div class="col-lg-6">
            <div class="product-details">
              <h1 class="product-title">@Model.Name</h1>

              <div class="product-rating mb-3">
                <div class="stars">
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star-half-alt"></i>
                </div>
                <span class="rating-text">(28 đánh giá)</span>
                <a href="#reviews" class="review-link">| Xem đánh giá</a>
              </div>

              <div class="product-price mb-4">
                <span class="price-current text-danger h4">@Model.Price</span>
              </div>

              <div class="product-description mb-4">
                <p>
                  @Model.Description
                </p>
              </div>

              <!-- Product Options -->
              <div class="product-options mb-4">
                <div class="option-group mb-3">
                  <label class="option-label">Quy mô bánh: @Model.CakeSize</label>
                </div>
              </div>

              <!-- Quantity and Buttons -->
              @* <div class="product-buttons mb-4">
                <div class="quantity-selector mr-3">
                  <button class="qty-btn" onclick="decreaseQty()">-</button>
                  <input type="number" id="quantity" value="1" min="1" />
                  <button class="qty-btn" onclick="increaseQty()">+</button>
                </div>
                <a 
                  asp-controller="Cart" asp-action="AddCartItem" asp-route-ProductDetailId="@Model.Id" asp-route-ProductId="@Model.ProductId"
                  class="btn btn-primary btn-lg flex-grow-1"
                >
                  <i class="fas fa-shopping-cart"></i> Thêm vào giỏ hàng
                </a>
              </div> *@
              <form asp-controller="Cart" asp-action="AddCartItem" method="post">
                
                <input type="hidden" name="ProductDetailId" value="@Model.Id" />
                <input type="hidden" name="ProductId" value="@Model.ProductId" />

                <div class="product-buttons mb-4 d-flex align-items-center">

                    <div class="quantity-selector mr-3 d-flex align-items-center">
                        <button type="button" class="qty-btn" onclick="decreaseQty()">-</button>

                        <input type="number" id="quantity" name="quantity" value="1" min="1" style="width:70px;text-align:center"/>

                        <button type="button" class="qty-btn" onclick="increaseQty()">+</button>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                        <i class="fas fa-shopping-cart"></i> Thêm vào giỏ hàng
                    </button>

                </div>
              </form>

              <button class="btn btn-outline-danger btn-block mb-3">
                <i class="fas fa-heart"></i> Thêm vào danh sách yêu thích
              </button>

              <!-- Product Meta -->
              <div class="product-meta">
                <div class="meta-item">
                  <span class="meta-label">Danh mục:</span>
                  <span class="meta-value">@Model.CategoryName</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Tình trạng:</span>
                  <span class="meta-value text-success">Còn hàng</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Chia sẻ:</span>
                  <div class="social-share">
                    <a href="#"><i class="fab fa-facebook"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-pinterest"></i></a>
                    <a href="#"><i class="fab fa-whatsapp"></i></a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    @section Scripts{
<script>
function increaseQty() {
    let qty = document.getElementById("quantity");
    qty.value = parseInt(qty.value) + 1;
}

function decreaseQty() {
    let qty = document.getElementById("quantity");
    if (qty.value > 1) {
        qty.value = parseInt(qty.value) - 1;
    }
}
</script>
}