@using Presentation.ViewModels
@{
    ViewData["Title"] = "Cửa hàng - Bánh kem sinh nhật";
    Layout = "~/Views/Shared/_LayoutClient.cshtml";
}
@model List<ProductListViewModel>

<style>
    .shop-section {
        padding: 60px 0;
        min-height: calc(100vh - 400px);
    }

    .shop-header {
        text-align: center;
        margin-bottom: 50px;
    }

    .shop-title {
        font-family: 'Playfair Display', serif;
        font-size: 42px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 15px;
    }

    .shop-subtitle {
        color: #999;
        font-size: 16px;
        margin-bottom: 0;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 30px;
        margin-bottom: 50px;
    }

    .product-item {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .product-item:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(212, 165, 116, 0.15);
    }

    .product-image-wrapper {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #f5f1ed 0%, #f9f6f2 100%);
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .product-item:hover .product-image-wrapper img {
        transform: scale(1.05);
    }

    .product-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background: #e74c3c;
        color: white;
        padding: 5px 12px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
        z-index: 2;
    }

    .wishlist-btn {
        position: absolute;
        bottom: 10px;
        right: 10px;
        width: 40px;
        height: 40px;
        background: white;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        transition: all 0.3s;
        color: #ccc;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        z-index: 3;
    }

    .wishlist-btn:hover {
        background: #d4a574;
        color: white;
        transform: scale(1.1);
    }

    .product-info {
        padding: 20px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .product-name {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .product-rating {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 12px;
        font-size: 14px;
    }

    .product-rating i {
        color: #ffc107;
        font-size: 12px;
    }

    .product-rating span {
        color: #999;
        font-size: 12px;
        margin-left: 5px;
    }

    .product-price {
        margin-bottom: 15px;
    }

    .price {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        font-weight: 700;
        color: #d4a574;
    }

    .product-actions {
        display: flex;
        gap: 10px;
        margin-top: auto;
    }

    .btn-view {
        flex: 1;
        padding: 10px 15px;
        background: #d4a574;
        color: white;
        border: none;
        border-radius: 6px;
        text-decoration: none;
        text-align: center;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-view:hover {
        background: #c29456;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(212, 165, 116, 0.3);
        color: white;
        text-decoration: none;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-icon {
        font-size: 80px;
        color: #e0e0e0;
        margin-bottom: 20px;
    }

    .empty-title {
        font-family: 'Playfair Display', serif;
        font-size: 28px;
        font-weight: 700;
        color: #999;
        margin-bottom: 10px;
    }

    .empty-text {
        color: #bbb;
        font-size: 16px;
        margin-bottom: 30px;
    }

    .filter-section {
        background: white;
        padding: 25px;
        border-radius: 8px;
        margin-bottom: 30px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .filter-title {
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 15px;
        font-size: 16px;
    }

    .filter-options {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-option {
        padding: 8px 15px;
        background: #f5f1ed;
        border: 1px solid transparent;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.3s;
        font-size: 14px;
    }

    .filter-option:hover,
    .filter-option.active {
        background: #d4a574;
        color: white;
        border-color: #d4a574;
    }

    @@media (max-width: 768px) {
        .shop-title {
            font-size: 28px;
        }

        .products-grid {
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 15px;
        }

        .filter-options {
            flex-direction: column;
        }

        .filter-option {
            width: 100%;
        }
    }
</style>

<!-- Shop Section -->
<section class="shop-section">
    <div class="container">
        <div class="shop-header">
            <h1 class="shop-title">🎂 Cửa hàng bánh kem</h1>
            <p class="shop-subtitle">Tìm kiếm và lựa chọn bánh ý yếu thích của bạn</p>
        </div>
