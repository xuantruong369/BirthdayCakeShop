        @await Component.InvokeAsync("CategoryMenu")

        @if (Model != null && Model.Count > 0)
        {
            <div class="products-grid">
                @foreach (var item in Model)
                {
                    <div class="product-item">
                        <div class="product-image-wrapper">
                            <img src="@Url.Content("~/Client/img/product/" + @item.ImageUrl)" alt="@item.Name" />
                            <span class="product-badge">Hot</span>
                            <button class="wishlist-btn" type="button">
                                <i class="far fa-heart"></i>
                            </button>
                        </div>
                        <div class="product-info">
                            <h3 class="product-name">@item.Name</h3>
                            <div class="product-rating">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star-half-alt"></i>
                                <span>(28 đánh giá)</span>
                            </div>
                            <div class="product-price">
                                <span class="price">@item.Price VNĐ</span>
                            </div>
                            <div class="product-actions">
                                <a asp-controller="Product" asp-action="GetProductDetail" asp-route-maSp="@item.Id"
                                       class="btn-view">
                                    <i class="fas fa-eye"></i> Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-inbox"></i>
                </div>
                <h2 class="empty-title">Không có sản phẩm nào</h2>
                <p class="empty-text">Rất tiếc, cửa hàng hiện không có sản phẩm</p>
            </div>
        }
    </div>
</section>
            