    <!-- Filter Section -->
    <div class="filter-section">
      <h3 class="filter-title">🔍 Lọc theo danh mục</h3>
      <div class="filter-options">
        <button class="filter-option active">Tất cả</button>
        <button class="filter-option">Bánh Vanilla</button>
        <button class="filter-option">Bánh Chocolate</button>
        <button class="filter-option">Bánh Strawberry</button>
