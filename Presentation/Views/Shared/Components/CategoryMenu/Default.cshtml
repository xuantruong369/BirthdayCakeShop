@using Presentation.ViewModels
@model List<CategoryMenuView>


<!-- Filter Section -->
<div class="filter-section">
    <h3 class="filter-title">🔍 Lọc theo danh mục</h3>
    <div class="filter-options">
        <a class="filter-option active" asp-controller="Shop" asp-action="Index">Tất cả</a>
        @foreach (var item in Model)
        {
            <a class="filter-option" data-id="@item.CategoryId" asp-controller="Shop" asp-action="ProductByCategory"
               asp-route-categoryId="@item.CategoryId">@item.CategoryName</a>
        }
    </div>
</div>

<script>
    const params = new URLSearchParams(window.location.search);
    const currentId = params.get("categoryId");

    const buttons = document.querySelectorAll('.filter-option');

    buttons.forEach(btn => {
        btn.classList.remove('active');

        // Nút "Tất cả"
        if (!currentId && btn.innerText.trim() === "Tất cả") {
            btn.classList.add('active');
        }

        // Nút category
        if (btn.dataset.id && btn.dataset.id === currentId) {
            btn.classList.add('active');
        }
    });
</script>