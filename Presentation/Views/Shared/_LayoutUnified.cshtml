<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Birthday Cake Shop</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet" />
    
    <!-- Design System CSS -->
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    
    <!-- Admin Specific CSS -->
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
</head>

<body>
    @{
        var controllerName = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var showSidebar = new[] { "Admin", "Customer" }.Contains(controllerName);
        var sidebarClass = showSidebar ? "" : "hide-sidebar";
    }

    <!-- Add hide-sidebar class to body if needed -->
    <script>
            @if (!showSidebar)
                {
                    <text>document.body.classList.add('hide-sidebar');</text>
            }
    </script>

    <!-- Sidebar Navigation -->
    <aside class="sidebar @sidebarClass" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <i class="fas fa-birthday-cake"></i>
                <span>Bánh Sinh Nhật</span>
            </div>
            <button class="sidebar-toggle" id="sidebarToggle">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <h6 class="nav-section-title">Menu Chính</h6>
                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                    <i class="fas fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                    <i class="fas fa-box"></i>
                    <span>Sản phẩm</span>
                </a>
                <a class="nav-link" asp-controller="Admin" asp-action="OrderList">
                    <i class="fas fa-receipt"></i>
                    <span>Đơn hàng</span>
                </a>
            </div>

            <div class="nav-section">
                <h6 class="nav-section-title">Quản lý</h6>
                <a class="nav-link" asp-controller="Admin" asp-action="CategoryList">
                    <i class="fas fa-list"></i>
                    <span>Danh mục</span>
                </a>
                <a class="nav-link" asp-controller="Admin" asp-action="CustomerList">
                    <i class="fas fa-users"></i>
                    <span>Khách hàng</span>
                </a>
                <a class="nav-link" asp-controller="Admin" asp-action="VoucherList">
                    <i class="fas fa-ticket-alt"></i>
                    <span>Vouchers</span>
                </a>
            </div>

            <div class="nav-section">
                <h6 class="nav-section-title">Khác</h6>
                <a class="nav-link" asp-controller="Admin" asp-action="Reports">
                    <i class="fas fa-chart-bar"></i>
                    <span>Báo cáo</span>
                </a>
                <a class="nav-link" asp-controller="Admin" asp-action="Settings">
                    <i class="fas fa-cog"></i>
                    <span>Cài đặt</span>
                </a>
            </div>
        </nav>

        <div class="sidebar-footer">
            <a class="nav-link" asp-controller="Home" asp-action="Index" title="Xem cửa hàng">
                <i class="fas fa-external-link-alt"></i>
                <span>Xem cửa hàng</span>
            </a>
        </div>
    </aside>

    <!-- Top Navigation -->
    <header class="topnav">
        <div class="topnav-left">
            <button class="btn-menu" id="menuToggle">
                <i class="fas fa-bars"></i>
            </button>
            <div class="topnav-breadcrumb">
                @RenderSection("Breadcrumb", required: false)
            </div>
        </div>

        <div class="topnav-right">
            <!-- Search -->
            <div class="topnav-search">
                <input type="text" class="form-control" placeholder="Tìm kiếm..." />
            </div>

            <!-- Notifications -->
            <div class="topnav-item dropdown">
                <button class="btn btn-icon" data-bs-toggle="dropdown">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#">Đơn hàng mới</a></li>
                    <li><a class="dropdown-item" href="#">Sản phẩm hết hàng</a></li>
                    <li><a class="dropdown-item" href="#">Bình luận mới</a></li>
                </ul>
            </div>

            <!-- Messages -->
            <div class="topnav-item dropdown">
                <button class="btn btn-icon" data-bs-toggle="dropdown">
                    <i class="fas fa-envelope"></i>
                    <span class="notification-badge">2</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#">Tin nhắn từ khách hàng</a></li>
                    <li><a class="dropdown-item" href="#">Phản hồi từ hệ thống</a></li>
                </ul>
            </div>

            <!-- User Profile -->
            <div class="topnav-item dropdown">
                <button class="btn btn-user" data-bs-toggle="dropdown">
                    <img src="~/Admin/images/faces/face1.jpg" alt="User" class="user-avatar" />
                    <span class="user-name">Admin</span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#profile"><i class="fas fa-user me-2"></i>Hồ sơ</a></li>
                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings"><i
                        class="fas fa-cog me-2"></i>Cài đặt</a></li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>
                        <li><a class="dropdown-item" asp-controller="Auth" asp-action="Logout"><i
                            class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Main Content -->
            <main class="main-content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>

            <!-- Footer -->
            <footer class="footer">
                <div class="footer-text">
                    <p>&copy; 2026 Birthday Cake Shop. All rights reserved.</p>
                </div>
                <div class="footer-links">
                    <a href="#">Quy định</a>
                    <a href="#">Bảo mật</a>
                    <a href="#">Hỗ trợ</a>
                </div>
            </footer>

            <!-- Scripts -->
            <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
            <script src="~/js/admin-layout.js" asp-append-version="true"></script>
            @await RenderSectionAsync("Scripts", required: false)
        </body>

    </html>
