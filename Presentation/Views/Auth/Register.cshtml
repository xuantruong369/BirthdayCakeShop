<form asp-action="Register" method="post" class="pt-3">

    <div class="form-group">
        <input asp-for="Username" class="form-control form-control-lg" placeholder="Tên đăng nhập">
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input asp-for="CustomerName" class="form-control form-control-lg" placeholder="Họ và tên">
        <span asp-validation-for="CustomerName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input asp-for="Phone" class="form-control form-control-lg" placeholder="Số điện thoại">
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input asp-for="Address" class="form-control form-control-lg" placeholder="Địa chỉ">
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input asp-for="PasswordHash" type="password" class="form-control form-control-lg" placeholder="Mật khẩu">
        <span asp-validation-for="PasswordHash" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" placeholder="Xác nhận mật khẩu">
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <div class="mb-4">
        <div class="form-check">
            <label class="form-check-label text-muted">
                <input type="checkbox" class="form-check-input"> Tôi đồng ý với Điều khoản và Điều kiện
            </label>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-block btn-gradient-primary btn-lg font-weight-medium auth-form-btn">
            ĐĂNG KÝ
        </button>
    </div>

    <div class="text-center mt-4 font-weight-light">
        Đã có tài khoản?
        <a asp-controller="Auth" asp-action="Login" class="text-primary">ĐĂNG NHẬP</a>
    </div>

</form>
              </div>
