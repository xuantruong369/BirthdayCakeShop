@using Presentation.ViewModels


@{
    ViewData["Title"] = "Danh sách đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@model List<OrderListItemViewModel>
<div class="main-panel">
    <div class="content-wrapper">
        <div class="page-header">
            <h3 class="page-title"> Danh sách đơn hàng </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="#">Quản trị</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Đơn hàng</li>
                </ol>
            </nav>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="card">
                <div class="card-body">
                    <div class="alert alert-info mb-0">
                        Chưa có đơn hàng nào.
                    </div>
                </div>
            </div>
        }
        else
        {
            @foreach (var order in Model)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
                            <div>
                                <h4 class="card-title mb-1">Đơn hàng #@order.OrderId</h4>
                                <p class="text-muted mb-0">
                                    Thời điểm đặt: @order.OrderDate
                                </p>
                            </div>
                            <div class="text-md-end mt-3 mt-md-0">
                                <h5 class="text-primary mb-0">
                                    Tổng tiền: @order.TotalAmount VNĐ
                                </h5>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 grid-margin stretch-card">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h5 class="mb-3">Thông tin khách hàng</h5>
                                        <p><strong>Họ và tên:</strong> @order.CustomerFullName</p>
                                        <p><strong>Phone:</strong> @order.Phone</p>
                                        <p><strong>Phương thức thanh toán:</strong> @order.PaymentMethod</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 grid-margin stretch-card">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h5 class="mb-3">Thông tin giao bánh</h5>
                                        <p><strong>Nơi giao bánh:</strong> @order.DeliveryAddress</p>
                                        <p><strong>Ngày giao:</strong> @order.DeliveryDate</p>
                                        <p><strong>Khung giờ giao:</strong> @order.DeliveryTimeSlot</p>
                                        <p><strong>Ghi chú đơn:</strong> @(string.IsNullOrWhiteSpace(order.OrderNote) ? "Không có" : order.OrderNote)</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <h5 class="mb-3">Danh sách sản phẩm</h5>
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Ảnh sản phẩm</th>
                                            <th>Tên sản phẩm</th>
                                            <th>Số lượng</th>
                                            <th>Giá bán</th>
                                            <th>Tổng giá</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var product in order.Products)
                                        {
                                            <tr>
                                                <td style="width: 110px;">
                                                    <img src="@Url.Content("~/Client/img/product/" + @product.ProductImage)"
                                                         alt="@product.ProductName"
                                                         style="width:80px;height:80px;object-fit:cover;border-radius:8px;" />
                                                </td>
                                                <td>@product.ProductName</td>
                                                <td>@product.Quantity</td>
                                                <td>@product.UnitPrice VNĐ</td>
                                                <td>@product.TotalPrice VNĐ</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="mt-3 text-end">
                            <span class="badge badge-gradient-primary p-2" style="font-size:14px;">
                                Tổng đơn: @order.TotalAmount VNĐ
                            </span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>