@using Presentation.ViewModels

@{
    ViewData["Title"] = "Danh sách đơn hàng";
    Layout = "~/Views/Shared/_LayoutUnified.cshtml";
}

@model List<OrderListItemViewModel>

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#">Admin</a></li>
            <li class="breadcrumb-item active">Đơn hàng</li>
        </ol>
    </nav>
}

<!-- Page Header -->
<div class="mb-4">
    <h1 class="page-title">Danh sách đơn hàng</h1>
    <p class="page-subtitle">Quản lý và theo dõi tất cả đơn hàng của khách hàng</p>
</div>

@if (Model == null || !Model.Any())
{
    <div class="card">
        <div class="card-body">
            <div class="alert alert-info mb-0">
                <i class="fas fa-info-circle"></i> Chưa có đơn hàng nào
            </div>
        </div>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card order-card mb-4">
            <div class="card-body">
                <!-- Order Header -->
                <div class="order-header mb-4">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                        <div>
                            <h5 class="order-id mb-2">
                                <i class="fas fa-receipt"></i> Đơn hàng #@order.OrderId
                            </h5>
                            <p class="text-muted small mb-0">
                                <i class="fas fa-calendar-alt"></i> @order.OrderDate?.ToString("dd/MM/yyyy HH:mm")
                            </p>
                        </div>
                        <div class="text-end">
                            <div class="order-total mb-2">
                                <span class="text-muted small d-block">Tổng tiền</span>
                                <h5 class="primary-color mb-0">@string.Format("{0:N0}", order.TotalAmount) VNĐ</h5>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Customer & Delivery Info -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="info-section">
                            <h6 class="section-title">
                                <i class="fas fa-user-circle"></i> Khách hàng
                            </h6>
                            <div class="info-content">
                                <p class="mb-2">
                                    <strong>Tên:</strong> @order.CustomerFullName
                                </p>
                                <p class="mb-2">
                                    <strong>Điện thoại:</strong> @order.Phone
                                </p>
                                <p class="mb-2">
                                    <strong>Thanh toán:</strong>
                                    <span class="badge badge-pill" style="background-color: #d4a574;">
                                        @order.PaymentMethod
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="info-section">
                            <h6 class="section-title">
                                <i class="fas fa-map-marker-alt"></i> Giao hàng
                            </h6>
                            <div class="info-content">
                                <p class="mb-2">
                                    <strong>Địa chỉ:</strong> @order.DeliveryAddress
                                </p>
                                <p class="mb-2">
                                    <strong>Ngày giao:</strong> @order.DeliveryDate?.ToString("dd/MM/yyyy")
                                </p>
                                <p class="mb-2">
                                    <strong>Khung giờ:</strong> @order.DeliveryTimeSlot
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Products Table -->
                <div class="products-section">
                    <h6 class="section-title mb-3">
                        <i class="fas fa-box"></i> Danh sách sản phẩm
                    </h6>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th width="80">Ảnh</th>
                                    <th>Sản phẩm</th>
                                    <th class="text-center" width="80">SL</th>
                                    <th class="text-end" width="120">Đơn giá</th>
                                    <th class="text-end" width="120">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in order.Products)
                                {
                                    <tr>
                                        <td>
                                            <img src="@Url.Content("~/Client/img/product/" + @product.ProductImage)"
                                                 alt="@product.ProductName" class="product-thumbnail" />
                                        </td>
                                        <td>
                                            <span class="product-name">@product.ProductName</span>
                                        </td>
                                        <td class="text-center">@product.Quantity</td>
                                        <td class="text-end">@string.Format("{0:N0}", product.UnitPrice) VNĐ</td>
                                        <td class="text-end fw-bold">@string.Format("{0:N0}", product.TotalPrice) VNĐ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Order Summary -->
                <div class="order-summary mt-4">
                    @if (!string.IsNullOrWhiteSpace(order.OrderNote))
                    {
                        <p class="mb-3">
                            <strong>Ghi chú:</strong> @order.OrderNote
                        </p>
                    }
                    <div class="summary-row">
                        <span>Tổng cộng:</span>
                        <span class="primary-color fw-bold">@string.Format("{0:N0}", order.TotalAmount) VNĐ</span>
                    </div>
                </div>
            </div>
        </div>
    }
}

<style>
    .order-card {
        border: 1px solid #f0f0f0;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .order-card:hover {
        box-shadow: 0 4px 12px rgba(212, 165, 116, 0.15);
    }

    .order-header {
        padding-bottom: 15px;
        border-bottom: 1px solid #f5f1ed;
    }

    .order-id {
        color: #2c2c2c;
        font-weight: 700;
        margin: 0;
    }

    .primary-color {
        color: #d4a574 !important;
    }

    .info-section {
        padding: 15px;
        background: #f9f6f2;
        border-radius: 8px;
    }

    .section-title {
        color: #2c2c2c;
        font-weight: 700;
        margin-bottom: 12px;
        font-size: 13px;
        text-transform: uppercase;
    }

    .info-content {
        font-size: 13px;
    }

    .info-content p {
        margin: 0;
        color: #666;
    }

    .info-content strong {
        color: #2c2c2c;
    }

    .product-thumbnail {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #f0f0f0;
    }

    .product-name {
        font-weight: 500;
        color: #2c2c2c;
    }

    .table {
        margin-bottom: 0;
        font-size: 13px;
    }

    .table thead {
        background: #f9f6f2;
    }

    .table thead th {
        color: #666;
        font-weight: 600;
        border: none;
        padding: 12px;
        text-transform: uppercase;
        font-size: 11px;
    }

    .table tbody td {
        vertical-align: middle;
        padding: 12px;
        border-bottom: 1px solid #f5f1ed;
    }

    .table tbody tr:last-child td {
        border-bottom: none;
    }

    .products-section {
        border-top: 1px solid #f5f1ed;
        padding-top: 15px;
        margin-top: 15px;
    }

    .order-summary {
        border-top: 2px solid #f5f1ed;
        padding-top: 15px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        font-size: 14px;
    }

    .badge-pill {
        font-size: 11px;
        padding: 4px 10px;
        color: white !important;
    }
</style>