@{
    ViewData["Title"] = "Thêm sản phẩm";
    Layout = "~/Views/Shared/_LayoutUnified.cshtml";
}
@model CreateProduct

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#">Admin</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="ProductList">Sản phẩm</a></li>
            <li class="breadcrumb-item active">Thêm mới</li>
        </ol>
    </nav>
}

<!-- Page Header -->
<div class="mb-4">
    <h1 class="page-title">Thêm sản phẩm mới</h1>
    <p class="page-subtitle">Nhập thông tin chi tiết để tạo sản phẩm mới</p>
</div>

<!-- Form Container -->
<div class="row">
    <div class="col-lg-8">
        <form asp-action="CreateProduct" asp-controller="Admin" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <!-- Basic Information -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">📋 Thông tin cơ bản</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">🎂 Danh mục</label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select form-control">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ProductName" class="form-label">Tên sản phẩm</label>
                        <input asp-for="ProductName" class="form-control" placeholder="Vd: Bánh Chocolate Đặc Biệt" />
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả chi tiết</label>
                        <textarea asp-for="Description" class="form-control" rows="5"
                                  placeholder="Nhập mô tả đầy đủ về sản phẩm..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Price & Size -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">💰 Giá và kích thước</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label">Giá (VNĐ)</label>
                            <input asp-for="Price" type="number" step="1000" class="form-control"
                                   placeholder="Vd: 450000" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CakeSize" class="form-label">Kích thước bánh</label>
                            <input asp-for="CakeSize" class="form-control" placeholder="Vd: 16cm x 16cm" />
                            <span asp-validation-for="CakeSize" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Flavor" class="form-label">🍰 Hương vị</label>
                        <input asp-for="Flavor" class="form-control" placeholder="Vd: Chocolate, Vanilla, Strawberry" />
                        <span asp-validation-for="Flavor" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Images -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">📸 Hình ảnh</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Thumbnail" class="form-label">Ảnh đại diện (Thumbnail)</label>
                        <div class="image-upload-area">
                            <input asp-for="Thumbnail" type="file" class="form-control" accept="image/*"
                                   id="thumbnailInput" />
                        </div>
                        <small class="text-muted">Kích thước: 400x400px, Định dạng: JPG, PNG</small>
                        <span asp-validation-for="Thumbnail" class="text-danger d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Images" class="form-label">Ảnh chi tiết sản phẩm</label>
                        <div class="image-upload-area">
                            <input asp-for="Images" type="file" class="form-control" accept="image/*" multiple
                                   id="imagesInput" />
                        </div>
                        <small class="text-muted">Tối đa 5 ảnh, kích thước mỗi ảnh tối thiểu 800x800px</small>
                        <span asp-validation-for="Images" class="text-danger d-block"></span>
                    </div>

                    <div id="imagePreview" class="image-preview-grid"></div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-save"></i> Thêm sản phẩm
                </button>
                <a asp-action="Index" asp-controller="Admin" class="btn btn-secondary btn-lg">
                    <i class="fas fa-times"></i> Hủy
                </a>
            </div>
        </form>
    </div>

    <!-- Sidebar Info -->
    <div class="col-lg-4">
        <div class="info-card">
            <h6 class="info-title">
                <i class="fas fa-lightbulb"></i> Mẹo thêm sản phẩm
            </h6>
            <ul class="info-list">
                <li>Tên sản phẩm nên rõ ràng và mô tả được đặc điểm chính</li>
                <li>Mô tả chi tiết giúp khách hàng hiểu rõ hơn về sản phẩm</li>
                <li>Giá phải phù hợp với chi phí sản xuất và lợi nhuận</li>
                <li>Ảnh đại diện nên có chất lượng cao và hấp dẫn</li>
                <li>Thêm nhiều ảnh chi tiết để khách hàng có thể xem rõ hơn</li>
            </ul>
        </div>

        <div class="info-card">
            <h6 class="info-title">
                <i class="fas fa-check-circle"></i> Danh sách kiểm tra
            </h6>
            <div class="checklist">
                <div class="check-item">
                    <input type="checkbox" id="check1" />
                    <label for="check1">Tên sản phẩm</label>
                </div>
                <div class="check-item">
                    <input type="checkbox" id="check2" />
                    <label for="check2">Mô tả chi tiết</label>
                </div>
                <div class="check-item">
                    <input type="checkbox" id="check3" />
                    <label for="check3">Giá chính xác</label>
                </div>
                <div class="check-item">
                    <input type="checkbox" id="check4" />
                    <label for="check4">Ảnh đại diện</label>
                </div>
                <div class="check-item">
                    <input type="checkbox" id="check5" />
                    <label for="check5">Ảnh chi tiết</label>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .image-upload-area {
        border: 2px dashed #d4a574;
        border-radius: 8px;
        padding: 30px;
        text-align: center;
        background: #f9f6f2;
        cursor: pointer;
        transition: all 0.3s;
    }

    .image-upload-area:hover {
        background: #f5f1ed;
        border-color: #c29456;
    }

    .image-preview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .image-preview-item {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 1;
    }

    .image-preview-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .info-card {
        background: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        margin-bottom: 20px;
    }

    .info-title {
        color: #d4a574;
        font-weight: 700;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .info-list li {
        padding: 8px 0;
        color: #666;
        font-size: 13px;
        border-bottom: 1px solid #f0f0f0;
    }

    .info-list li:last-child {
        border-bottom: none;
    }

    .checklist {
        display: grid;
        gap: 10px;
    }

    .check-item {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .check-item input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: #d4a574;
    }

    .check-item label {
        font-size: 13px;
        color: #666;
        margin: 0;
        cursor: pointer;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 30px;
    }

    .form-actions .btn {
        flex: 1;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const imagesInput = document.getElementById('imagesInput');
            const preview = document.getElementById('imagePreview');

            if (imagesInput) {
                imagesInput.addEventListener('change', function (e) {
                    preview.innerHTML = '';
                    const files = Array.from(e.target.files);
                    
                    files.forEach(file => {
                        const reader = new FileReader();
                        reader.onload = function (event) {
                            const div = document.createElement('div');
                            div.className = 'image-preview-item';
                            div.innerHTML = `<img src="${event.target.result}" alt="Preview" />`;
                            preview.appendChild(div);
                        };
                        reader.readAsDataURL(file);
                    });
                });
            }
        });
    </script>
}