@{
    ViewData["Title"] = "Báo cáo & Thống kê";
    Layout = "~/Views/Shared/_LayoutUnified.cshtml";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#">Admin</a></li>
            <li class="breadcrumb-item active">Báo cáo</li>
        </ol>
    </nav>
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Báo cáo & Thống kê</h1>
        <p class="page-subtitle">Xem các báo cáo chi tiết về kinh doanh và hiệu suất</p>
    </div>
    <button class="btn btn-primary">
        <i class="fas fa-download"></i> Xuất báo cáo
    </button>
</div>

<!-- Date Range Filter -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Từ ngày</label>
                <input type="date" class="form-control" value="2024-04-01" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Đến ngày</label>
                <input type="date" class="form-control" value="2024-04-30" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Loại báo cáo</label>
                <select class="form-control">
                    <option>Tất cả</option>
                    <option>Doanh thu</option>
                    <option>Sản phẩm bán chạy</option>
                    <option>Khách hàng</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100">
                    <i class="fas fa-search"></i> Lọc
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Key Metrics -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-header">
                <h6 class="metric-title">Tổng doanh thu</h6>
                <i class="fas fa-money-bill-wave metric-icon"></i>
            </div>
            <h2 class="metric-value">125.5M</h2>
            <p class="metric-change positive">
                <i class="fas fa-arrow-up"></i> 12.5% so với tháng trước
            </p>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-header">
                <h6 class="metric-title">Tổng đơn hàng</h6>
                <i class="fas fa-shopping-cart metric-icon"></i>
            </div>
            <h2 class="metric-value">456</h2>
            <p class="metric-change positive">
                <i class="fas fa-arrow-up"></i> 8.3% so với tháng trước
            </p>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-header">
                <h6 class="metric-title">Số khách hàng mới</h6>
                <i class="fas fa-user-plus metric-icon"></i>
            </div>
            <h2 class="metric-value">85</h2>
            <p class="metric-change positive">
                <i class="fas fa-arrow-up"></i> 15.2% so với tháng trước
            </p>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-header">
                <h6 class="metric-title">Tỷ lệ chuyển đổi</h6>
                <i class="fas fa-percent metric-icon"></i>
            </div>
            <h2 class="metric-value">3.2%</h2>
            <p class="metric-change negative">
                <i class="fas fa-arrow-down"></i> 0.5% so với tháng trước
            </p>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="row">
    <div class="col-lg-8 mb-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Doanh thu theo ngày</h5>
                <select class="form-select form-select-sm w-auto">
                    <option>30 ngày</option>
                    <option>60 ngày</option>
                    <option>90 ngày</option>
                </select>
            </div>
            <div class="card-body">
                <div class="chart-placeholder">
                    <div
                        style="height: 300px; background: linear-gradient(to right, transparent, rgba(212, 165, 116, 0.1)); border-radius: 8px; display: flex; align-items: flex-end; justify-content: space-around; padding: 20px;">
                        <div style="width: 3%; height: 30%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 45%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 60%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 50%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 70%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 75%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 65%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 80%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 85%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                        <div style="width: 3%; height: 90%; background: #d4a574; border-radius: 4px 4px 0 0;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Sản phẩm bán chạy</h5>
            </div>
            <div class="card-body">
                <div class="top-products">
                    <div class="product-row">
                        <div class="product-rank">1</div>
                        <div class="product-name">Bánh Chocolate Đặc</div>
                        <div class="product-sales">850</div>
                    </div>
                    <div class="product-row">
                        <div class="product-rank">2</div>
                        <div class="product-name">Bánh Vanilla Trắng</div>
                        <div class="product-sales">720</div>
                    </div>
                    <div class="product-row">
                        <div class="product-rank">3</div>
                        <div class="product-name">Bánh Red Velvet</div>
                        <div class="product-sales">645</div>
                    </div>
                    <div class="product-row">
                        <div class="product-rank">4</div>
                        <div class="product-name">Bánh Strawberry</div>
                        <div class="product-sales">580</div>
                    </div>
                    <div class="product-row">
                        <div class="product-rank">5</div>
                        <div class="product-name">Bánh Carrot Cake</div>
                        <div class="product-sales">520</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Revenue by Category -->
<div class="row">
    <div class="col-lg-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Doanh thu theo danh mục</h5>
            </div>
            <div class="card-body">
                <div class="category-stats">
                    <div class="category-row">
                        <div class="category-name">Bánh Chocolate</div>
                        <div class="category-bar">
                            <div style="width: 85%; background: #d4a574; height: 20px; border-radius: 4px;"></div>
                        </div>
                        <div class="category-value">42.5M</div>
                    </div>
                    <div class="category-row">
                        <div class="category-name">Bánh Vanilla</div>
                        <div class="category-bar">
                            <div style="width: 65%; background: #c29456; height: 20px; border-radius: 4px;"></div>
                        </div>
                        <div class="category-value">32.5M</div>
                    </div>
                    <div class="category-row">
                        <div class="category-name">Bánh Custom</div>
                        <div class="category-bar">
                            <div style="width: 45%; background: #e8c8a0; height: 20px; border-radius: 4px;"></div>
                        </div>
                        <div class="category-value">22.5M</div>
                    </div>
                    <div class="category-row">
                        <div class="category-name">Bánh Khác</div>
                        <div class="category-bar">
                            <div style="width: 28%; background: #f0d9c8; height: 20px; border-radius: 4px;"></div>
                        </div>
                        <div class="category-value">14M</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Phương thức thanh toán</h5>
            </div>
            <div class="card-body">
                <div class="payment-methods">
                    <div class="payment-row">
                        <div class="payment-icon cod">
                            <i class="fas fa-money-bill"></i>
                        </div>
                        <div class="payment-info">
                            <h6>Thanh toán khi nhận</h6>
                            <small>65% đơn hàng</small>
                        </div>
                        <div class="payment-value">81.625M</div>
                    </div>
                    <div class="payment-row">
                        <div class="payment-icon bank">
                            <i class="fas fa-university"></i>
                        </div>
                        <div class="payment-info">
                            <h6>Chuyển khoản ngân hàng</h6>
                            <small>25% đơn hàng</small>
                        </div>
                        <div class="payment-value">31.375M</div>
                    </div>
                    <div class="payment-row">
                        <div class="payment-icon card">
                            <i class="fas fa-credit-card"></i>
                        </div>
                        <div class="payment-info">
                            <h6>Thẻ tín dụng</h6>
                            <small>10% đơn hàng</small>
                        </div>
                        <div class="payment-value">12.55M</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .metric-card {
        background: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .metric-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .metric-title {
        font-size: 13px;
        color: #999;
        margin: 0;
        font-weight: 600;
    }

    .metric-icon {
        font-size: 24px;
        color: #d4a574;
    }

    .metric-value {
        font-size: 32px;
        font-weight: 700;
        color: #1a1a1a;
        margin: 10px 0;
    }

    .metric-change {
        font-size: 12px;
        margin: 0;
    }

    .metric-change.positive {
        color: #28a745;
    }

    .metric-change.negative {
        color: #dc3545;
    }

    .top-products {
        display: grid;
        gap: 12px;
    }

    .product-row {
        display: grid;
        grid-template-columns: 30px 1fr 60px;
        gap: 10px;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .product-rank {
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg, #d4a574, #c29456);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 12px;
    }

    .product-name {
        font-size: 13px;
        color: #666;
    }

    .product-sales {
        font-weight: 700;
        color: #1a1a1a;
        text-align: right;
    }

    .category-stats {
        display: grid;
        gap: 15px;
    }

    .category-row {
        display: grid;
        gap: 10px;
    }

    .category-name {
        font-size: 13px;
        font-weight: 600;
        color: #666;
    }

    .category-bar {
        height: 20px;
        background: #f5f1ed;
        border-radius: 4px;
        overflow: hidden;
    }

    .category-value {
        font-weight: 700;
        color: #d4a574;
        font-size: 13px;
    }

    .payment-methods {
        display: grid;
        gap: 15px;
    }

    .payment-row {
        display: grid;
        grid-template-columns: 50px 1fr 80px;
        gap: 15px;
        align-items: center;
        padding: 15px;
        background: #f9f6f2;
        border-radius: 6px;
    }

    .payment-icon {
        width: 50px;
        height: 50px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
    }

    .payment-icon.cod {
        background: linear-gradient(135deg, #d4a574, #c29456);
    }

    .payment-icon.bank {
        background: linear-gradient(135deg, #28a745, #20c997);
    }

    .payment-icon.card {
        background: linear-gradient(135deg, #17a2b8, #0c5460);
    }

    .payment-info h6 {
        margin: 0 0 3px 0;
        font-size: 13px;
        font-weight: 600;
        color: #1a1a1a;
    }

    .payment-info small {
        color: #999;
        font-size: 11px;
    }

    .payment-value {
        font-weight: 700;
        color: #1a1a1a;
        text-align: right;
    }
</style>
