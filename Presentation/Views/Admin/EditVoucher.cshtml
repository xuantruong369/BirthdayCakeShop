@{
    ViewData["Title"] = "Quản lý voucher";
    Layout = "~/Views/Shared/_LayoutUnified.cshtml";
}
@model CreateEditVoucher

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#">Admin</a></li>
            <li class="breadcrumb-item active">Vouchers</li>
        </ol>
    </nav>
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Quản lý voucher</h1>
        <p class="page-subtitle">Tạo và quản lý mã giảm giá cho khách hàng</p>
    </div>
</div>

<!-- Main Content Grid -->
<div class="row">
    <!-- Form Section -->
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-gradient p-4 border-0">
                <h5 class="card-title mb-0">
                    <i class="fas fa-plus-circle me-2"></i>Chỉnh sửa voucher
                </h5>
            </div>
            <div class="card-body p-4">
                <form class="voucher-form" id="voucherForm" asp-action="EditVoucher" asp-controller="Admin"
                      method="post" enctype="multipart/form-data">
                    <!-- Validation -->
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="VoucherId" id="VoucherId" />

                    <div class="mb-3">
                        <label asp-for="VoucherCode" class="form-label fw-500">Mã voucher</label>
                        <input asp-for="VoucherCode" type="text" class="form-control form-control-lg"
                               placeholder="Vd: SUMMER2024" />
                        <span asp-validation-for="VoucherCode" class="text-danger"></span>

                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="IsPercentage" class="form-label fw-500">Loại</label>
                            <select asp-for="IsPercentage" class="form-control form-control-lg">
                                <option value="">-- Chọn loại --</option>
                                <option value="false">Phần trăm (%)</option>
                                <option value="true">Số tiền cố định (đ)</option>
                            </select>
                            <span asp-validation-for="IsPercentage" class="text-danger"></span>

                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DiscountValue" class="form-label fw-500">Giá trị</label>
                            <input asp-for="DiscountValue" type="number" class="form-control form-control-lg"
                                   placeholder="Vd: 20" />
                            <span asp-validation-for="DiscountValue" class="text-danger"></span>

                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label fw-500">Thời gian áp dụng</label>
                            <input asp-for="StartDate" type="date" class="form-control form-control-lg" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label fw-500">Ngày hết hạn</label>
                            <input asp-for="EndDate" type="date" class="form-control form-control-lg" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>

                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
               
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i>Lưu thay đổi
                        </button>
                        <a asp-controller="Admin" asp-action="VoucherList" class="btn btn-light btn-lg">
                            <i class="fas fa-times me-2"></i>Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Form Styling */
    .voucher-form {
        font-family: 'Poppins', sans-serif;
    }

    .voucher-form .form-label {
        color: #333;
        font-size: 0.95rem;
        margin-bottom: 0.75rem;
        display: block;
    }

    .form-control-lg {
        padding: 0.75rem 1rem;
        font-size: 1rem;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .form-control-lg:focus {
        border-color: #d4a574;
        box-shadow: 0 0 0 0.2rem rgba(212, 165, 116, 0.15);
    }

    /* Card Header Styling */
    .card-header.bg-gradient {
        background: linear-gradient(135deg, #d4a574 0%, #c29456 100%) !important;
        color: white;
    }

    .card-header .card-title {
        font-size: 1.25rem;
        color: white;
        font-weight: 600;
    }

    /* Stats Section */
    .stat-card {
        background: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        display: flex;
        gap: 15px;
        align-items: center;
        height: 100%;
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
        transform: translateY(-2px);
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 8px;
        background: linear-gradient(135deg, #d4a574, #c29456);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    .stat-icon.active {
        background: linear-gradient(135deg, #28a745, #20c997);
    }

    .stat-icon.expired {
        background: linear-gradient(135deg, #dc3545, #fd7e14);
    }

    .stat-label {
        font-size: 12px;
        color: #999;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-value {
        font-size: 28px;
        font-weight: 700;
        margin: 0;
        color: #333;
    }

    /* Button Styling */
    .btn-lg {
        padding: 0.75rem 1.5rem;
        font-weight: 500;
    }

    .btn-primary {
        background: linear-gradient(135deg, #d4a574, #c29456);
        border: none;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #c29456, #b0844a);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(212, 165, 116, 0.3);
    }

    .btn-light {
        border: 1px solid #e0e0e0;
        color: #666;
    }

    .btn-light:hover {
        background: #f8f8f8;
        border-color: #d0d0d0;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-title {
            font-size: 1.75rem;
        }

        .stat-card {
            padding: 15px;
        }

        .stat-value {
            font-size: 24px;
        }
    }
</style>
