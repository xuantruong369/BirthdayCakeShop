@using Presentation.ViewModels
@model AdminGetVouchers

@{
    ViewData["Title"] = "Quản lý voucher";
    Layout = "~/Views/Shared/_LayoutUnified.cshtml";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#">Admin</a></li>
            <li class="breadcrumb-item active">Vouchers</li>
        </ol>
    </nav>
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Quản lý voucher</h1>
        <p class="page-subtitle">Tạo và quản lý mã giảm giá cho khách hàng</p>
    </div>
    <a asp-controller="Admin" asp-action="CreateVoucher" class="btn btn-primary">
        <i class="fas fa-plus"></i> Tạo voucher
    </a>
</div>

<!-- Quick Stats -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="stat-card">
            <div class="stat-icon active">
                <i class="fas fa-tag"></i>
            </div>
            <div class="stat-info">
                <p class="stat-label">Voucher hoạt động</p>
                <h3 class="stat-value">@Model.TotalVoucherActive</h3>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="stat-card">
            <div class="stat-icon expired">
                <i class="fas fa-calendar-times"></i>
            </div>
            <div class="stat-info">
                <p class="stat-label">Voucher hết hạn</p>
                <h3 class="stat-value">@Model.TotalVoucherNoActive</h3>
            </div>
        </div>
    </div>
    @* <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="stat-info">
                <p class="stat-label">Tổng tiết kiệm</p>
                <h3 class="stat-value">25M</h3>
            </div>
        </div>
    </div> *@
</div>

<!-- Filters & Search -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" class="form-control" id="searchInput" placeholder="Tìm theo mã voucher..." />
            </div>
            <div class="col-md-3">
                <select class="form-control" id="statusFilter">
                    <option value="">Tất cả trạng thái</option>
                    <option value="active">Hoạt động</option>
                    <option value="expired">Hết hạn</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-control" id="typeFilter">
                    <option value="">Tất cả loại</option>
                    <option value="percentage">Phần trăm</option>
                    <option value="fixed">Số tiền cố định</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" id="resetFilter">
                    <i class="fas fa-refresh"></i> Reset
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Vouchers Table -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover" id="vouchersTable">
            <thead>
                <tr>
                    <th>Mã voucher</th>
                    @* <th>Tên</th> *@
                    <th>Loại</th>
                    <th>Giá trị</th>
                    @* <th>Số lần dùng</th> *@
                    <th>Hạn sử dụng</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                
                @foreach (var item in Model.adminGetVoucherItems)
                {
                    <tr>
                        <td><strong>@item.VoucherCode</strong></td>
                        <td><span class="badge bg-info">@item.strIsPercentage</span></td>
                        <td>@item.DiscountValue</td>
                        <td>@item.EndDate?.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge bg-success">@item.strIsActive</span></td>
                        <td>
                            <div class="table-actions">
                                <a asp-controller="Admin" asp-action="EditVoucher" asp-route-voucherId="@item.VoucherId"
                                       class="btn btn-sm btn-edit" title="Chỉnh sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-controller="Admin" asp-action="DeleteVoucher" asp-route-voucherId="@item.VoucherId"
                                       class="btn btn-sm btn-delete" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .stat-card {
        background: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 8px;
        background: linear-gradient(135deg, #d4a574, #c29456);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .stat-icon.active {
        background: linear-gradient(135deg, #28a745, #20c997);
    }

    .stat-icon.expired {
        background: linear-gradient(135deg, #dc3545, #fd7e14);
    }

    .stat-label {
        font-size: 12px;
        color: #999;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 700;
        margin: 0;
    }

    .table-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }

    .btn-edit,
    .btn-delete {
        padding: 0.4rem 0.6rem;
        font-size: 0.85rem;
    }
</style>

<!-- Pagination -->
<nav aria-label="Page navigation" class="mt-4">
    <ul class="pagination justify-content-center">
        <li class="page-item">
            <a class="page-link" href="#" onclick="changePage(1); return false;">Trước</a>
        </li>
        <li class="page-item active">
            <a class="page-link" href="#" onclick="changePage(1); return false;">1</a>
        </li>
        <li class="page-item">
            <a class="page-link" href="#" onclick="changePage(2); return false;">Tiếp</a>
        </li>
    </ul>
</nav>

<script>
    let currentPage = 1;
    const pageSize = 10;

    document.addEventListener('DOMContentLoaded', function () {
        // === SERVER-SIDE SEARCH ===
        const searchInput = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const typeFilter = document.getElementById('typeFilter');
        const resetFilterBtn = document.getElementById('resetFilter');

        // Hàm gọi API search từ server
        async function performSearch(page = 1) {
            const search = searchInput.value.trim();
            const status = statusFilter.value || '';
            const type = typeFilter.value || '';

            try {
                const response = await fetch(`/Admin/SearchVouchers?search=${encodeURIComponent(search)}&status=${status}&type=${type}&page=${page}&pageSize=${pageSize}`);
                const data = await response.json();

                if (data.success) {
                    updateVoucherTable(data.items);
                    updatePagination(data.currentPage, data.totalPages);
                    currentPage = data.currentPage;
                } else {
                    console.error('Lỗi tìm kiếm:', data.message);
                    alert('Lỗi: ' + data.message);
                }
            } catch (error) {
                console.error('Lỗi:', error);
                alert('Có lỗi xảy ra khi tìm kiếm');
            }
        }

        // Cập nhật bảng voucher
        function updateVoucherTable(vouchers) {
            const tbody = document.querySelector('#vouchersTable tbody');
            tbody.innerHTML = '';

            if (!vouchers || vouchers.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4"><p class="text-muted mb-0">Không có voucher nào</p></td></tr>';
                return;
            }

            vouchers.forEach(voucher => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><strong>${voucher.voucherCode}</strong></td>
                    <td><span class="badge bg-info">${voucher.strIsPercentage}</span></td>
                    <td>${voucher.discountValue}</td>
                    <td>${voucher.endDate}</td>
                    <td><span class="badge bg-success">${voucher.strIsActive}</span></td>
                    <td>
                        <div class="table-actions">
                            <a href="/Admin/EditVoucher?voucherId=${voucher.voucherId}"
                               class="btn btn-sm btn-edit" title="Chỉnh sửa">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a href="/Admin/DeleteVoucher?voucherId=${voucher.voucherId}"
                               class="btn btn-sm btn-delete" title="Xóa"
                               onclick="return confirm('Bạn có chắc muốn xóa voucher này?');">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        // Cập nhật pagination
        function updatePagination(currentPageNum, totalPages) {
            const paginationNav = document.querySelector('.pagination');
            paginationNav.innerHTML = '';

            // Nút Trước
            const prevLi = document.createElement('li');
            prevLi.className = `page-item ${currentPageNum === 1 ? 'disabled' : ''}`;
            prevLi.innerHTML = `<a class="page-link" href="#" onclick="changePage(${currentPageNum - 1}); return false;">Trước</a>`;
            paginationNav.appendChild(prevLi);

            // Các trang
            for (let i = 1; i <= totalPages; i++) {
                const li = document.createElement('li');
                li.className = `page-item ${i === currentPageNum ? 'active' : ''}`;
                li.innerHTML = `<a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>`;
                paginationNav.appendChild(li);
            }

            // Nút Tiếp
            const nextLi = document.createElement('li');
            nextLi.className = `page-item ${currentPageNum === totalPages ? 'disabled' : ''}`;
            nextLi.innerHTML = `<a class="page-link" href="#" onclick="changePage(${currentPageNum + 1}); return false;">Tiếp</a>`;
            paginationNav.appendChild(nextLi);
        }

        // Event listener cho search
        let searchTimeout;
        searchInput.addEventListener('keyup', function () {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                currentPage = 1;
                performSearch(1);
            }, 300);
        });

        // Event listener cho filters
        statusFilter.addEventListener('change', function () {
            currentPage = 1;
            performSearch(1);
        });

        typeFilter.addEventListener('change', function () {
            currentPage = 1;
            performSearch(1);
        });

        // Reset filter
        resetFilterBtn.addEventListener('click', function () {
            searchInput.value = '';
            statusFilter.value = '';
            typeFilter.value = '';
            currentPage = 1;
            performSearch(1);
        });

        // Hàm đổi trang (global)
        window.changePage = function (page) {
            if (page < 1) page = 1;
            currentPage = page;
            performSearch(page);
        };
    });
</script>
