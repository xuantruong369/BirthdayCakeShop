@using Presentation.ViewModels
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutUnified.cshtml";
}

@model AdminDashboard

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#">Admin</a></li>
            <li class="breadcrumb-item active">Dashboard</li>
        </ol>
    </nav>
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Xin chào! Đây là bảng điều khiển quản trị của bạn</p>
    </div>
    <div>
        <button class="btn btn-primary">
            <i class="fas fa-refresh"></i> Làm mới
        </button>
    </div>
</div>

<!-- Metrics Cards Row -->
<div class="row mb-4">
    <!-- Total Orders -->
    <div class="col-md-6 col-lg-3 mb-3">
        <div class="metric-card">
            <div class="metric-header">
                <div>
                    <div class="metric-label">Tổng đơn hàng</div>
                    <div class="metric-value">@Model.TotalOrderByMonth</div>
                </div>
                <div class="metric-icon">
                    <i class="fas fa-shopping-cart"></i>
                </div>
            </div>
            <div class="metric-change positive">
                <i class="fas fa-arrow-up"></i> @Model.TotalOrderVSLastMonth so với tháng trước
            </div>
        </div>
    </div>

    <!-- Total Revenue -->
    <div class="col-md-6 col-lg-3 mb-3">
        <div class="metric-card">
            <div class="metric-header">
                <div>
                    <div class="metric-label">Tổng doanh thu</div>
                    <div class="metric-value">@Utils.FormatNumber(@Model.TotalRevenueByMonth)</div>
                </div>
                <div class="metric-icon" style="background-color: #d4edda; color: var(--success-color);">
                    <i class="fas fa-money-bill-wave"></i>
                </div>
            </div>
            <div class="metric-change positive">
                <i class="fas fa-arrow-up"></i>@Utils.FormatNumber(@Model.TotalRevenueVSLastMonth) so với tháng trước
            </div>
        </div>
    </div>

    <!-- Total Products -->
    <div class="col-md-6 col-lg-3 mb-3">
        <div class="metric-card">
            <div class="metric-header">
                <div>
                    <div class="metric-label">Tổng sản phẩm</div>
                    <div class="metric-value">@Model.TotalProduct</div>
                </div>
                <div class="metric-icon" style="background-color: #e3f2fd; color: var(--info-color);">
                    <i class="fas fa-box"></i>
                </div>
            </div>
            <div class="metric-change positive">
                <i class="fas fa-arrow-up"></i> @Model.TotalNewProductByMonth sản phẩm mới
            </div>
        </div>
    </div>

    <!-- Total Customers -->
    <div class="col-md-6 col-lg-3 mb-3">
        <div class="metric-card">
            <div class="metric-header">
                <div>
                    <div class="metric-label">Khách hàng</div>
                    <div class="metric-value">@Model.TotalCustomer</div>
                </div>
                <div class="metric-icon" style="background-color: #fce4ec; color: #e91e63;">
                    <i class="fas fa-users"></i>
                </div>
            </div>
            <div class="metric-change positive">
                <i class="fas fa-arrow-up"></i> @Model.TotalNewCustomerByMonth khách mới
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row mb-4">
    <!-- Revenue Chart -->
    <div class="col-lg-12 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Doanh thu theo tháng</h5>
                <p class="text-muted mb-3">Biểu đồ doanh thu 12 tháng qua</p>
                @* <canvas id="revenueChart" style="height: 300px;"></canvas> *@
                <div style="height: 250px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    @* <!-- Order Status Chart -->
    <div class="col-lg-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Trạng thái đơn hàng</h5>
                <p class="text-muted mb-3">Phân bổ đơn hàng</p>
                <canvas id="statusChart" style="height: 300px;"></canvas>
                <div style="height: 250px;">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div> *@
</div>

@* <!-- Second Row Charts -->
<div class="row mb-4">
    <!-- Top Products -->
    <div class="col-lg-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Sản phẩm bán chạy</h5>
                <p class="text-muted mb-3">Top 5 sản phẩm bán chạy nhất</p>
                <canvas id="productsChart" style="height: 300px;"></canvas>
                <div style="height: 250px;">
                    <canvas id="productsChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="col-lg-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Hoạt động gần đây</h5>
                <div class="activity-list">
