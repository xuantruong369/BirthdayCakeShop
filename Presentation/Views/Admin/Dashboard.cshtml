</div> *@

<!-- Recent Orders Table -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Đơn hàng gần đây</h5>
                    <a asp-controller="Admin" asp-action="OrderList" class="btn btn-sm btn-primary">Xem tất cả</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Khách hàng</th>
                                <th>Số điện thoại</th>
                                <th>Địa chỉ</th>
                                <th>Phương thức thanh toán</th>
                                <th>Tổng tiền</th>
                                <th>Ngày giao</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.AdminOrderListDashes)
                            {
                                <tr>
                                    <td><strong>@item.CustomerFullName</strong></td>
                                    <td>@item.Phone</td>
                                    <td>@item.DeliveryAddress</td>
                                    <td><span class="badge badge-success">@item.PaymentMethod</span></td>
                                    <td>@string.Format("{0:N0}", @item.TotalAmount) VNĐ</td>
                                    <td>@item.DeliveryDate?.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Styles for Activity List -->
<style>
    .activity-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .activity-item {
        display: flex;
        gap: 1rem;
        padding: 0.75rem;
        border-left: 2px solid var(--border-color);
        padding-left: 1rem;
    }

    .activity-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1rem;
    }

    .activity-content {
        flex: 1;
    }

    .activity-content p {
        margin-bottom: 0.25rem;
        font-size: 0.95rem;
    }

    .badge-warning {
        background-color: #fff3cd;
        color: #856404;
    }
</style>

<!-- Chart.js Script -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>

<script>
    // Revenue Chart
    const revenueCtx = document.getElementById('revenueChart').getContext('2d');
    new Chart(revenueCtx, {
    type: 'line',
    data: {
    labels: ['T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'T8', 'T9', 'T10', 'T11', 'T12'],
    datasets: [{
    label: 'Doanh thu (VNĐ)',
    data: [@Utils.ScaleToK(@Model.TotalOrderByEveryMonth[0]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[1]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[2]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[3]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[4]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[5]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[6]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[7]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[8]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[9]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[10]), @Utils.ScaleToK(@Model.TotalOrderByEveryMonth[11])],
    borderColor: '#d4a574',
    backgroundColor: 'rgba(212, 165, 116, 0.1)',
    borderWidth: 2,
    fill: true,
    tension: 0.4,
    pointBackgroundColor: '#d4a574',
    pointBorderColor: '#fff',
    pointBorderWidth: 2,
    pointRadius: 5
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
    legend: {
    display: false
    }
    },
    scales: {
    y: {
    beginAtZero: true,
    ticks: {
    callback: function (value) {
    return value.toFixed(1) + 'K';
    }
    }
    }
    }
    }
    });

    // Order Status Chart
    const statusCtx = document.getElementById('statusChart').getContext('2d');
    new Chart(statusCtx, {
    type: 'doughnut',
    data: {
    labels: ['Hoàn thành', 'Đang xử lý', 'Chờ giao', 'Hủy'],
    datasets: [{
    data: [45, 23, 18, 14],
    backgroundColor: [
    '#27ae60',
    '#f39c12',
    '#3498db',
    '#e74c3c'
    ],
    borderColor: '#fff',
    borderWidth: 2
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
    legend: {
    position: 'bottom'
    }
    }
    }
    });

    // Top Products Chart
    const productsCtx = document.getElementById('productsChart').getContext('2d');
    new Chart(productsCtx, {
    type: 'bar',
    data: {
    labels: ['Bánh Chocolate', 'Bánh Vanilla', 'Bánh Strawberry', 'Bánh Matcha', 'Bánh Caramel'],
    datasets: [{
    label: 'Số lượng bán',
    data: [156, 134, 98, 87, 65],
    backgroundColor: '#d4a574',
    borderColor: '#b89968',
    borderWidth: 1
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
    legend: {
    display: false
    }
    },
    scales: {
    y: {
    beginAtZero: true
    }
    }
    }
    });
</script>
