                            <i class="fas fa-check-circle"></i>
                        </div>
                        <div class="activity-content">
                            <p class="mb-0"><strong>Đơn hàng #12345 hoàn thành</strong></p>
                            <small class="text-muted">2 phút trước</small>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon" style="background-color: #fff3cd; color: var(--warning-color);">
                            <i class="fas fa-exclamation-circle"></i>
                        </div>
                        <div class="activity-content">
                            <p class="mb-0"><strong>Bánh Chocolate hết hàng</strong></p>
                            <small class="text-muted">15 phút trước</small>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon" style="background-color: #d1ecf1; color: var(--info-color);">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <div class="activity-content">
                            <p class="mb-0"><strong>Khách hàng mới đăng ký</strong></p>
